<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StickerPicker.ViewModels"
             x:Class="StickerPicker.Controls.StickerTile"
             x:DataType="vm:StickerItemViewModel">
  <Border x:Name="Root"
          Classes="tile"
          Width="{Binding TileSize}"
          Height="{Binding TileSize}"
          PointerPressed="OnPointerPressed"
          ToolTip.Tip="{Binding FileName}">
    <Panel>
      <Image Source="{Binding Thumbnail}"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             VerticalAlignment="Center" />
    </Panel>
    <Border.ContextMenu>
      <ContextMenu>
        <MenuItem Header="编辑标签" x:Name="EditTagsItem" />
        <MenuItem Header="移动到分类" x:Name="MoveSubmenu" />
        <MenuItem Header="删除" x:Name="DeleteItem" />
      </ContextMenu>
    </Border.ContextMenu>
  </Border>
</UserControl>

<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="StickerPicker.App"
             xmlns:local="using:StickerPicker"
             x:DataType="local:App"
             RequestedThemeVariant="Dark"
             Name="StickerPicker">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://StickerPicker/Themes/SteamTheme.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://StickerPicker/Themes/SteamStyles.axaml" />
  </Application.Styles>

  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon Icon="/Assets/avalonia-logo.ico"
                ToolTipText="StickerPicker" />
    </TrayIcons>
  </TrayIcon.Icons>
</Application>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StickerPicker.ViewModels"
        xmlns:controls="using:StickerPicker.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
        x:Class="StickerPicker.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="STICKERPICKER"
        Width="960"
        Height="640"
        MinWidth="720"
        MinHeight="480">

  <Panel>
    <DockPanel>
      <!-- ===== Heavy dark header bar (Steam signature) ===== -->
      <Border DockPanel.Dock="Top" Classes="headerbar" Padding="14,9">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <TextBlock Text="STICKERPICKER" Classes="header" FontSize="14" VerticalAlignment="Center" />
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Button Classes="subtle" Content="刷新" Command="{Binding RefreshLibraryCommand}" />
            <Button Classes="subtle" Content="设置" Command="{Binding OpenSettingsCommand}" />
          </StackPanel>
        </Grid>
      </Border>

      <!-- ===== Status bar (dense, single line) ===== -->
      <Border DockPanel.Dock="Bottom"
              Background="{DynamicResource SteamBgBrush}"
              BorderBrush="{DynamicResource SteamBorderBrush}"
              BorderThickness="0,1,0,0"
              Padding="10,3">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="{Binding StatusText}" Classes="muted" FontSize="11" VerticalAlignment="Center" />
          <TextBlock Grid.Column="1"
                     Text="{Binding ErrorMessage}"
                     Foreground="{DynamicResource SteamErrorBrush}"
                     FontSize="11"
                     VerticalAlignment="Center"
                     Margin="12,0,0,0" />
        </Grid>
      </Border>

      <!-- ===== Sidebar: dense category nav ===== -->
      <Border DockPanel.Dock="Left"
              Background="{DynamicResource SteamPanelBrush}"
              BorderBrush="{DynamicResource SteamBorderBrush}"
              BorderThickness="0,0,1,0"
              Width="184">
        <DockPanel>
          <!-- Sidebar header + add button -->
          <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="8,8,4,4">
            <TextBlock Text="分类" Classes="section" VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Classes="subtle"
                    Content="+"
                    Width="24"
                    Height="22"
                    Padding="0"
                    Click="OnCreateCategoryClick"
                    HorizontalContentAlignment="Center" />
          </Grid>

          <!-- Category actions (compact, icon-like text) -->
          <StackPanel DockPanel.Dock="Bottom" Spacing="2" Margin="4,4,4,6">
            <Button Classes="subtle"
                    Content="重命名"
                    Click="OnRenameCategoryClick"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    FontSize="11" />
            <Button Classes="subtle"
                    Content="删除"
                    Click="OnDeleteCategoryClick"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    FontSize="11" />
          </StackPanel>

          <ListBox ItemsSource="{Binding Categories}"
                   SelectedItem="{Binding SelectedCategory}"
                   Margin="2,2,2,2">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:CategoryItemViewModel">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding Name}"
                             VerticalAlignment="Center"
                             TextTrimming="CharacterEllipsis" />
                  <Border Grid.Column="1"
                          Background="{DynamicResource SteamPanelAltBrush}"
                          CornerRadius="2"
                          Padding="6,1"
                          Margin="6,0,0,0"
                          IsVisible="{Binding !IsVirtual}">
                    <TextBlock Text="{Binding StickerCount}"
                               Classes="muted"
                               FontSize="10" />
                  </Border>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- ===== Main content: toolbar + dense grid ===== -->
      <DockPanel Background="{DynamicResource SteamBgBrush}">
        <!-- Toolbar: search + imports -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SteamPanelBrush}"
                BorderBrush="{DynamicResource SteamBorderSoftBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBox PlaceholderText="搜索 tag / 文件名"
                     Text="{Binding SearchText}"
                     MinHeight="28" />
            <Button Grid.Column="1"
                    Classes="primary"
                    Content="导入文件"
                    Margin="8,0,0,0"
                    Click="OnImportFilesClick" />
            <Button Grid.Column="2"
                    Content="导入文件夹"
                    Margin="4,0,0,0"
                    Click="OnImportFolderClick" />
          </Grid>
        </Border>

        <!-- Dense sticker grid -->
        <ScrollViewer x:Name="StickerScroll"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="6">
          <ItemsControl ItemsSource="{Binding Stickers}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:StickerItemViewModel">
                <controls:StickerTile />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </DockPanel>

    <!-- ===== Settings overlay: animated inline panel ===== -->
    <Border x:Name="OverlayMask"
            IsVisible="False"
            Background="#B3000000"
            ZIndex="10">
      <Border x:Name="OverlayCard"
              Classes="panel"
              Width="460"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              BorderThickness="1"
              Padding="0"
              Opacity="0"
              RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
          <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
        </Border.RenderTransform>
        <Border.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" />
          </Transitions>
        </Border.Transitions>
        <DockPanel>
          <!-- Settings header -->
          <Border DockPanel.Dock="Top"
                  Classes="headerbar"
                  Padding="14,9">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="设置" Classes="header" />
              <Button Grid.Column="1"
                      Classes="subtle"
                      Content="✕"
                      Width="26"
                      Height="24"
                      Padding="0"
                      HorizontalContentAlignment="Center"
                      Command="{Binding CloseSettingsCommand}" />
            </Grid>
          </Border>

          <StackPanel Margin="16,12" Spacing="12">
            <!-- Theme -->
            <StackPanel Spacing="4">
              <TextBlock Text="主题" Classes="section" />
              <ComboBox ItemsSource="{Binding Settings.ThemeOptions}"
                        SelectedItem="{Binding Settings.Theme}"
                        HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- Always on top -->
            <CheckBox Content="窗口置顶"
                      IsChecked="{Binding Settings.AlwaysOnTop}" />

            <!-- Hover preview -->
            <CheckBox Content="鼠标悬停时显示大图"
                      IsChecked="{Binding Settings.HoverPreview}" />

            <!-- Hotkey -->
            <StackPanel Spacing="4">
              <TextBlock Text="全局热键" Classes="section" />
              <TextBlock Text="点击下方区域后按下组合键" Classes="muted" FontSize="11" />
              <Grid ColumnDefinitions="*,Auto">
                <controls:HotkeyCaptureBox Gesture="{Binding Settings.Hotkey, Mode=TwoWay}"
                                          GestureCaptured="OnHotkeyGestureCaptured" />
                <Button Grid.Column="1"
                        Classes="primary"
                        Content="应用"
                        Margin="6,0,0,0"
                        Command="{Binding Settings.SaveHotkeyCommand}" />
              </Grid>
            </StackPanel>

            <!-- Data root -->
            <StackPanel Spacing="4">
              <TextBlock Text="数据目录" Classes="section" />
              <TextBox Text="{Binding Settings.DataRootDisplay}" IsReadOnly="True" />
              <CheckBox Content="切换时复制现有数据"
                        IsChecked="{Binding Settings.CopyOnMigrate}" />
              <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                <Button Content="选择目录…"
                        Click="OnPickDataRootClick" />
                <Button Classes="subtle"
                        Content="恢复默认"
                        Command="{Binding Settings.UseDefaultDataRootCommand}" />
              </StackPanel>
            </StackPanel>

            <TextBlock Text="{Binding Settings.StatusMessage}"
                       Classes="muted"
                       TextWrapping="Wrap"
                       FontSize="11" />
          </StackPanel>
        </DockPanel>
      </Border>
    </Border>

    <!-- Hover preview popup -->
    <Border x:Name="HoverPreviewBorder"
            IsVisible="False"
            Opacity="0.92"
            ZIndex="20"
            Background="{DynamicResource SteamPanelBrush}"
            BorderBrush="{DynamicResource SteamBorderBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Padding="4"
            MaxWidth="400"
            MaxHeight="400">
      <Image x:Name="HoverPreviewImage"
             Stretch="Uniform"
             MaxWidth="392"
             MaxHeight="392" />
    </Border>
  </Panel>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:StickerPicker.ViewModels"
        xmlns:controls="using:StickerPicker.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="640"
        x:Class="StickerPicker.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="StickerPicker"
        Width="960"
        Height="640"
        MinWidth="720"
        MinHeight="480"
        PointerWheelChanged="OnPointerWheelChanged">

  <Panel>
    <DockPanel>
      <Border DockPanel.Dock="Bottom"
              Classes="panel"
              Padding="8,4"
              BorderThickness="0,1,0,0">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="{Binding StatusText}" Classes="muted" VerticalAlignment="Center" />
          <TextBlock Grid.Column="1"
                     Text="{Binding ErrorMessage}"
                     Foreground="#e74c3c"
                     VerticalAlignment="Center"
                     Margin="12,0,0,0" />
        </Grid>
      </Border>

      <Border DockPanel.Dock="Left"
              Classes="panel"
              Width="180"
              Margin="0,0,1,0"
              BorderThickness="0,0,1,0">
        <DockPanel>
          <StackPanel DockPanel.Dock="Bottom" Spacing="4" Margin="6">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Button Content="新建" Click="OnCreateCategoryClick" />
              <Button Content="重命名" Click="OnRenameCategoryClick" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Button Content="删除" Click="OnDeleteCategoryClick" />
              <Button Content="刷新" Command="{Binding RefreshLibraryCommand}" />
            </StackPanel>
          </StackPanel>
          <ListBox ItemsSource="{Binding Categories}"
                   SelectedItem="{Binding SelectedCategory}"
                   Margin="4">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:CategoryItemViewModel">
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <DockPanel Margin="8">
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,8">
          <TextBox PlaceholderText="搜索 tag / 文件名"
                   Text="{Binding SearchText}"
                   MinHeight="28" />
          <Button Grid.Column="1"
                  Content="导入文件"
                  Margin="8,0,0,0"
                  Click="OnImportFilesClick" />
          <Button Grid.Column="2"
                  Content="导入文件夹"
                  Margin="4,0,0,0"
                  Click="OnImportFolderClick" />
          <Button Grid.Column="3"
                  Content="设置"
                  Margin="4,0,0,0"
                  Command="{Binding OpenSettingsCommand}" />
        </Grid>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Stickers}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:StickerItemViewModel">
                <controls:StickerTile />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>
    </DockPanel>

    <Border IsVisible="{Binding IsSettingsOpen}"
            Background="#CC000000"
            ZIndex="10">
      <Border Classes="panel"
              Width="420"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Padding="16">
        <StackPanel Spacing="10">
          <TextBlock Text="设置" FontSize="18" FontWeight="SemiBold" />

          <TextBlock Text="主题" Classes="muted" />
          <ComboBox ItemsSource="{Binding Settings.ThemeOptions}"
                    SelectedItem="{Binding Settings.Theme}"
                    HorizontalAlignment="Stretch" />

          <CheckBox Content="窗口置顶"
                    IsChecked="{Binding Settings.AlwaysOnTop}" />

          <TextBlock Text="全局热键" Classes="muted" />
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Text="{Binding Settings.Hotkey}" />
            <Button Grid.Column="1"
                    Content="保存热键"
                    Margin="8,0,0,0"
                    Command="{Binding Settings.SaveHotkeyCommand}" />
          </Grid>

          <TextBlock Text="数据目录" Classes="muted" />
          <TextBox Text="{Binding Settings.DataRootDisplay}" IsReadOnly="True" />
          <CheckBox Content="切换时复制现有数据"
                    IsChecked="{Binding Settings.CopyOnMigrate}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="选择目录…" Click="OnPickDataRootClick" />
            <Button Content="恢复默认"
                    Command="{Binding Settings.UseDefaultDataRootCommand}" />
          </StackPanel>

          <TextBlock Text="{Binding Settings.StatusMessage}" Classes="muted" TextWrapping="Wrap" />

          <Button Content="关闭"
                  HorizontalAlignment="Right"
                  Command="{Binding CloseSettingsCommand}" />
        </StackPanel>
      </Border>
    </Border>
  </Panel>
</Window>

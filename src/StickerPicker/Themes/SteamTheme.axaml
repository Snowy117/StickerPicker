<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <CornerRadius x:Key="ControlCornerRadius">0</CornerRadius>
  <CornerRadius x:Key="OverlayCornerRadius">0</CornerRadius>

  <!-- Dark palette (Steam-like) -->
  <Color x:Key="SteamDarkBg">#171a21</Color>
  <Color x:Key="SteamDarkPanel">#1b2838</Color>
  <Color x:Key="SteamDarkPanelAlt">#2a475e</Color>
  <Color x:Key="SteamDarkBorder">#3d4450</Color>
  <Color x:Key="SteamDarkText">#c7d5e0</Color>
  <Color x:Key="SteamDarkMuted">#8f98a0</Color>
  <Color x:Key="SteamAccent">#66c0f4</Color>

  <!-- Light palette -->
  <Color x:Key="SteamLightBg">#e9e9e9</Color>
  <Color x:Key="SteamLightPanel">#f5f5f5</Color>
  <Color x:Key="SteamLightPanelAlt">#dcdcdc</Color>
  <Color x:Key="SteamLightBorder">#b0b0b0</Color>
  <Color x:Key="SteamLightText">#1b1b1b</Color>
  <Color x:Key="SteamLightMuted">#5a5a5a</Color>
  <Color x:Key="SteamLightAccent">#1a9cfc</Color>

  <SolidColorBrush x:Key="SteamBgBrush" Color="{StaticResource SteamDarkBg}" />
  <SolidColorBrush x:Key="SteamPanelBrush" Color="{StaticResource SteamDarkPanel}" />
  <SolidColorBrush x:Key="SteamPanelAltBrush" Color="{StaticResource SteamDarkPanelAlt}" />
  <SolidColorBrush x:Key="SteamBorderBrush" Color="{StaticResource SteamDarkBorder}" />
  <SolidColorBrush x:Key="SteamTextBrush" Color="{StaticResource SteamDarkText}" />
  <SolidColorBrush x:Key="SteamMutedBrush" Color="{StaticResource SteamDarkMuted}" />
  <SolidColorBrush x:Key="SteamAccentBrush" Color="{StaticResource SteamAccent}" />
</ResourceDictionary>

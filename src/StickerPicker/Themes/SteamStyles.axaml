<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:StickerPicker.Controls">

  <!-- ============================================================ -->
  <!-- Window & Text                                                -->
  <!-- ============================================================ -->
  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource SteamBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrush}" />
    <Setter Property="FontFamily" Value="Segoe UI, Noto Sans CJK SC, sans-serif" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <!-- Uppercase letter-spaced header text block -->
  <Style Selector="TextBlock.header">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrightBrush}" />
    <Setter Property="LetterSpacing" Value="0.8" />
  </Style>
  <Style Selector="TextBlock.section">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource SteamAccentBrush}" />
    <Setter Property="LetterSpacing" Value="0.6" />
    <Setter Property="FontSize" Value="11" />
  </Style>
  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource SteamMutedBrush}" />
  </Style>
  <Style Selector="TextBlock.bright">
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrightBrush}" />
  </Style>

  <!-- ============================================================ -->
  <!-- Panels & Borders                                             -->
  <!-- ============================================================ -->
  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource SteamPanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <!-- Heavy dark header bar: signature Steam top weight -->
  <Style Selector="Border.headerbar">
    <Setter Property="Background" Value="{DynamicResource SteamHeaderGradientBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,0,2" />
  </Style>

  <!-- ============================================================ -->
  <!-- Buttons                                                      -->
  <!-- ============================================================ -->
  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Background" Value="{DynamicResource SteamPanelAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="12,5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Transitions">
      <Setter.Value>
        <Transitions>
          <BrushTransition Duration="0:0:0.15" Property="Background" />
          <BrushTransition Duration="0:0:0.15" Property="BorderBrush" />
          <BrushTransition Duration="0:0:0.15" Property="Foreground" />
        </Transitions>
      </Setter.Value>
    </Setter>
  </Style>
  <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource SteamHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrightBrush}" />
    <Setter Property="Transitions">
      <Setter.Value>
        <Transitions>
          <BrushTransition Duration="0:0:0.15" Property="Background" />
          <BrushTransition Duration="0:0:0.15" Property="Foreground" />
        </Transitions>
      </Setter.Value>
    </Setter>
  </Style>
  <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SteamAccentDimBrush}" />
  </Style>

  <!-- Subtle variant -->
  <Style Selector="Button.subtle">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrush}" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="FontWeight" Value="Normal" />
  </Style>
  <Style Selector="Button.subtle:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Background" Value="{DynamicResource SteamPanelAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrightBrush}" />
  </Style>

  <!-- Primary: classic Steam green gradient + inner highlight -->
  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource SteamPrimaryBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamGreenTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="LetterSpacing" Value="0.3" />
  </Style>
  <Style Selector="Button.primary /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="BoxShadow" Value="0 1 0 0 #ffffff44" />
  </Style>
  <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SteamPrimaryHoverBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrightBrush}" />
  </Style>
  <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SteamPrimaryBrush}" />
  </Style>

  <!-- Danger: destructive confirm actions -->
  <Style Selector="Button.danger">
    <Setter Property="Background" Value="{DynamicResource SteamDangerBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrightBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamDangerBorderBrush}" />
  </Style>

  <!-- Icon-only square toolbar buttons -->
  <Style Selector="Button.icon">
    <Setter Property="Padding" Value="6" />
    <Setter Property="Width" Value="28" />
    <Setter Property="Height" Value="28" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <!-- ============================================================ -->
  <!-- TextBox / Hotkey capture                                     -->
  <!-- ============================================================ -->
  <Style Selector="TextBox">
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Background" Value="{DynamicResource SteamBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource SteamAccentBrush}" />
    <Setter Property="SelectionBrush" Value="{DynamicResource SteamAccentDimBrush}" />
    <Setter Property="Padding" Value="8,5" />
    <Setter Property="Transitions">
      <Setter.Value>
        <Transitions>
          <BrushTransition Duration="0:0:0.15" Property="BorderBrush" />
        </Transitions>
      </Setter.Value>
    </Setter>
  </Style>
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{DynamicResource SteamAccentBrush}" />
  </Style>

  <!-- ============================================================ -->
  <!-- HotkeyCaptureBox — listening state feedback                  -->
  <!-- ============================================================ -->
  <Style Selector="controls|HotkeyCaptureBox:focus /template/ Border#CaptureBorder">
    <Setter Property="BorderBrush" Value="{DynamicResource SteamAccentBrush}" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>
  <Style Selector="controls|HotkeyCaptureBox.listening /template/ Border#CaptureBorder">
    <Setter Property="BorderBrush" Value="{DynamicResource SteamAccentBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Style.Animations>
      <Animation Duration="0:0:0.9" IterationCount="INFINITE">
        <KeyFrame Cue="0%">
          <Setter Property="BoxShadow" Value="0 0 0 2 #66c0f4" />
        </KeyFrame>
        <KeyFrame Cue="50%">
          <Setter Property="BoxShadow" Value="0 0 0 4 #66c0f4" />
        </KeyFrame>
        <KeyFrame Cue="100%">
          <Setter Property="BoxShadow" Value="0 0 0 2 #66c0f4" />
        </KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

  <!-- ============================================================ -->
  <!-- ListBox — dense sidebar nav                                  -->
  <!-- ============================================================ -->
  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>
  <Style Selector="ListBoxItem">
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Padding" Value="10,5" />
    <Setter Property="Margin" Value="2,1" />
    <Setter Property="Transitions">
      <Setter.Value>
        <Transitions>
          <BrushTransition Duration="0:0:0.15" Property="Background" />
        </Transitions>
      </Setter.Value>
    </Setter>
  </Style>
  <Style Selector="ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="CornerRadius" Value="2" />
  </Style>
  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SteamPanelAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrightBrush}" />
  </Style>
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SteamAccentDimBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrightBrush}" />
  </Style>
  <Style Selector="ListBoxItem:selected:focus /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SteamAccentBrush}" />
    <Setter Property="Foreground" Value="#0d1419" />
  </Style>

  <!-- ============================================================ -->
  <!-- ComboBox / CheckBox                                          -->
  <!-- ============================================================ -->
  <Style Selector="ComboBox">
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Background" Value="{DynamicResource SteamBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderBrush}" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrush}" />
  </Style>

  <!-- ============================================================ -->
  <!-- ScrollViewer — thin Steam-style scrollbars                   -->
  <!-- ============================================================ -->
  <Style Selector="ScrollViewer">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ScrollBar.vertical">
    <Setter Property="Width" Value="10" />
  </Style>
  <Style Selector="ScrollBar.horizontal">
    <Setter Property="Height" Value="10" />
  </Style>
  <Style Selector="ScrollBar:vertical /template/ Border">
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Background" Value="{DynamicResource SteamBgBrush}" />
  </Style>
  <Style Selector="ScrollBar:horizontal /template/ Border">
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Background" Value="{DynamicResource SteamBgBrush}" />
  </Style>
  <Style Selector="ScrollBar Thumb">
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Background" Value="{DynamicResource SteamPanelAltBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Transitions">
      <Setter.Value>
        <Transitions>
          <BrushTransition Duration="0:0:0.15" Property="Background" />
        </Transitions>
      </Setter.Value>
    </Setter>
  </Style>
  <Style Selector="ScrollBar Thumb:pointerover">
    <Setter Property="Background" Value="{DynamicResource SteamAccentBrush}" />
  </Style>

  <!-- ============================================================ -->
  <!-- Sticker tile — brightness-like hover, sharp edges, dense     -->
  <!-- ============================================================ -->
  <Style Selector="Border.tile">
    <Setter Property="Background" Value="{DynamicResource SteamPanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderSoftBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="Padding" Value="2" />
    <Setter Property="Margin" Value="2" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Transitions">
      <Setter.Value>
        <Transitions>
          <BrushTransition Duration="0:0:0.15" Property="Background" />
          <BrushTransition Duration="0:0:0.15" Property="BorderBrush" />
        </Transitions>
      </Setter.Value>
    </Setter>
  </Style>
  <Style Selector="Border.tile:pointerover">
    <Setter Property="Background" Value="{DynamicResource SteamPanelAltBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamAccentBrush}" />
  </Style>
  <Style Selector="Border.tile:pressed">
    <Setter Property="Background" Value="{DynamicResource SteamAccentDimBrush}" />
  </Style>
</Styles>

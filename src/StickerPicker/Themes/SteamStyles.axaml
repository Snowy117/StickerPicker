<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource SteamBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrush}" />
  </Style>

  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource SteamPanelBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Background" Value="{DynamicResource SteamPanelAltBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="10,4" />
  </Style>
  <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SteamAccentBrush}" />
    <Setter Property="Foreground" Value="#111" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Background" Value="{DynamicResource SteamBgBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource SteamBorderBrush}" />
    <Setter Property="CaretBrush" Value="{DynamicResource SteamAccentBrush}" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="ListBoxItem">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="Margin" Value="0" />
  </Style>
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SteamPanelAltBrush}" />
  </Style>
  <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{DynamicResource SteamPanelAltBrush}" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource SteamTextBrush}" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource SteamMutedBrush}" />
  </Style>

  <Style Selector="ScrollViewer">
    <Setter Property="Background" Value="Transparent" />
  </Style>
</Styles>
